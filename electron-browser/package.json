{
  "name": "lamby",
  "description": "Lamby Desktop Application",
  "author": "Lamby",
  "private": true,
  "version": "1.0.0",
  "type": "commonjs",
  "main": "src/main.js",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.0.0",
    "innosetup-compiler": "^6.3.1"
  },
  "build": {
    "appId": "com.lamby.desktop",
    "productName": "Lamby",
    "asar": false,
    "directories": {
      "output": "../exe",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../server/bridge-connector.cjs",
        "to": "server/bridge-connector.cjs"
      },
      {
        "from": "../server/sandbox-dispatcher.cjs",
        "to": "server/sandbox-dispatcher.cjs"
      }
    ],
    "win": {
      "target": "dir",
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "build/icon.png",
      "category": "Development"
    }
  }
}

{
  "name": "lamby",
  "description": "Lamby Desktop Application",
  "author": "Lamby",
  "private": true,
  "version": "1.0.0",
  "type": "commonjs",
  "main": "src/main.js",
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.lamby.desktop",
    "productName": "Lamby",
    "asar": false,
    "directories": {
      "output": "../exe",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": "squirrel",
      "icon": "build/icon.ico"
    },
    "squirrelWindows": {
      "iconUrl": "file://build/icon.ico",
      "loadingGif": "build/installing.gif"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "build/icon.png",
      "category": "Development"
    }
  }
}

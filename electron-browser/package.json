{
  "name": "lamby",
  "description": "Lamby Desktop Application",
  "author": "Lamby",
  "private": true,
  "version": "1.0.0",
  "type": "commonjs",
  "main": "src/main.js",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.lamby.desktop",
    "productName": "Lamby",
    "asar": false,
    "directories": {
      "output": "../exe"
    },
    "files": [
      "src/**/*",
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": null,
      "uninstallerIcon": null
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Development"
    }
  }
}

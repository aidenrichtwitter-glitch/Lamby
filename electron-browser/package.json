{
  "name": "lamby",
  "description": "Lamby Desktop Application",
  "author": "Lamby",
  "private": true,
  "version": "1.0.0",
  "type": "commonjs",
  "main": "src/main.js",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.lamby.desktop",
    "productName": "Lamby",
    "asar": false,
    "directories": {
      "output": "../exe",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "shortcutName": "Lamby",
      "artifactName": "Lamby-Setup-${version}.${ext}",
      "perMachine": false,
      "uninstallDisplayName": "Lamby",
      "deleteAppDataOnUninstall": false,
      "include": "build/installer.nsh"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "build/icon.png",
      "category": "Development"
    }
  }
}
